+.album-object {
+  position: relative;
+  width: 100%;
+  max-width: 650px;
+  aspect-ratio: 1.45 / 1;
+  margin-bottom: 28px;
+  isolation: isolate;
+  perspective: 1200px;
+}
+
 .release-art {
+  --sleeve-rotate-x: 0deg;
+  --sleeve-rotate-y: 0deg;
+  --foil-x: 34%;
+  --foil-y: 24%;
   position: relative;
   display: block;
+  width: min(68%, 400px);
   aspect-ratio: 1 / 1;
+  padding: 0;
+  overflow: visible;
+  color: inherit;
+  border: 0;
+  border-radius: 0;
+  background: transparent;
+  appearance: none;
+  cursor: pointer;
+}
+
+.album-sleeve {
+  position: absolute;
+  top: 50%;
+  left: 2%;
+  z-index: 3;
+  transform:
+    translateY(-50%)
+    perspective(1100px)
+    rotateX(var(--sleeve-rotate-x))
+    rotateY(var(--sleeve-rotate-y));
+  transform-style: preserve-3d;
+  transition: transform 220ms cubic-bezier(0.2, 0.7, 0.2, 1);
+}
+
+.album-sleeve__cover {
+  position: absolute;
+  inset: 0;
+  display: block;
   overflow: hidden;
-  box-shadow: 18px 22px 0 rgba(225, 187, 45, 0.11), 0 28px 70px rgba(0, 0, 0, 0.38);
-  transition: transform 300ms cubic-bezier(0.2, 0.7, 0.2, 1), box-shadow 300ms ease;
+  background: #d8aa16;
+  box-shadow:
+    18px 22px 0 rgba(225, 187, 45, 0.11),
+    0 28px 70px rgba(0, 0, 0, 0.45),
+    inset -10px 0 18px rgba(55, 38, 0, 0.2);
+  transform: translateZ(0);
+  transition: box-shadow 300ms ease, transform 300ms cubic-bezier(0.2, 0.7, 0.2, 1);
 }
 
-.release-art::before {
+.album-sleeve__cover::before {
   content: "";
   position: absolute;
   inset: 10px;
-  z-index: 1;
+  z-index: 3;
   border: 1px solid rgba(9, 9, 10, 0.22);
   pointer-events: none;
 }
 
-.release-art:hover {
-  box-shadow: 10px 14px 0 rgba(225, 187, 45, 0.18), 0 28px 70px rgba(0, 0, 0, 0.45);
-  transform: rotate(-1.2deg) translateY(-5px);
-}
-
-.release-art img {
+.album-sleeve__cover img {
   width: 100%;
   height: 100%;
   object-fit: cover;
 }
 
-.release-art > span {
+.album-sleeve__foil {
+  position: absolute;
+  inset: -8%;
+  z-index: 2;
+  display: block;
+  overflow: hidden;
+  background:
+    radial-gradient(circle at var(--foil-x) var(--foil-y), rgba(255, 249, 204, 0.58), rgba(242, 213, 106, 0.18) 12%, transparent 29%),
+    linear-gradient(118deg, transparent 22%, rgba(255, 249, 211, 0.06) 36%, rgba(255, 238, 151, 0.32) 48%, transparent 63%);
+  mix-blend-mode: screen;
+  opacity: 0.34;
+  pointer-events: none;
+  transform: translateZ(6px);
+  transition: opacity 250ms ease;
+}
+
+.album-sleeve__foil::after {
+  content: "";
+  position: absolute;
+  inset: -35% -55%;
+  background: linear-gradient(105deg, transparent 36%, rgba(255, 249, 211, 0.46) 48%, rgba(225, 187, 45, 0.18) 54%, transparent 67%);
+  transform: translateX(-72%) rotate(4deg);
+  animation: album-foil-sweep 6.8s cubic-bezier(0.55, 0.08, 0.35, 0.98) infinite;
+}
+
+.album-sleeve__edge {
+  position: absolute;
+  top: 0;
+  right: 0;
+  bottom: 0;
+  z-index: 3;
+  display: block;
+  width: 7px;
+  background: linear-gradient(90deg, rgba(71, 45, 0, 0.08), rgba(255, 245, 186, 0.36), rgba(65, 42, 0, 0.24));
+  pointer-events: none;
+}
+
+.album-sleeve__action {
   position: absolute;
   right: 14px;
   bottom: 14px;
-  z-index: 2;
+  z-index: 5;
+  display: block;
   padding: 8px 11px;
   color: var(--paper);
   background: rgba(9, 9, 10, 0.9);
@@ -835,6 +917,153 @@ main,
   text-transform: uppercase;
 }
 
+.album-sleeve:hover .album-sleeve__cover,
+.album-sleeve:focus-visible .album-sleeve__cover {
+  box-shadow:
+    10px 14px 0 rgba(225, 187, 45, 0.18),
+    0 34px 80px rgba(0, 0, 0, 0.55),
+    inset -10px 0 18px rgba(55, 38, 0, 0.18);
+  transform: translateZ(12px) scale(1.012);
+}
+
+.album-sleeve:hover .album-sleeve__foil,
+.album-sleeve:focus-visible .album-sleeve__foil {
+  opacity: 0.62;
+}
+
+.album-insert {
+  position: absolute;
+  top: 50%;
+  left: 4%;
+  z-index: 1;
+  width: min(64%, 380px);
+  aspect-ratio: 1 / 1;
+  padding: clamp(24px, 3.2vw, 40px);
+  overflow: hidden;
+  color: #201b10;
+  background:
+    linear-gradient(100deg, rgba(118, 87, 12, 0.07), transparent 15%),
+    repeating-linear-gradient(0deg, rgba(72, 55, 18, 0.025) 0 1px, transparent 1px 4px),
+    #e9e2d1;
+  border: 1px solid rgba(255, 255, 255, 0.46);
+  box-shadow: 0 18px 55px rgba(0, 0, 0, 0.34);
+  transform: translate3d(0, -50%, 0) rotate(0.6deg);
+  transition:
+    transform 680ms cubic-bezier(0.16, 0.82, 0.2, 1),
+    box-shadow 500ms ease;
+}
+
+.album-insert::after {
+  content: "";
+  position: absolute;
+  inset: 10px;
+  border: 1px solid rgba(74, 57, 17, 0.17);
+  pointer-events: none;
+}
+
+.album-insert__kicker,
+.album-insert__catalog {
+  position: relative;
+  z-index: 1;
+  margin: 0;
+  color: #78601e;
+  font-family: var(--font-display);
+  font-size: clamp(0.48rem, 0.8vw, 0.62rem);
+  font-weight: 600;
+  letter-spacing: 0.12em;
+  text-transform: uppercase;
+}
+
+.album-insert__title {
+  position: relative;
+  z-index: 1;
+  margin: 5px 0 0;
+  color: #17130b;
+  font-family: var(--font-display);
+  font-size: clamp(1rem, 2vw, 1.45rem);
+  line-height: 1.2;
+}
+
+.album-insert__catalog {
+  position: absolute;
+  right: clamp(24px, 3.2vw, 40px);
+  bottom: clamp(22px, 3vw, 36px);
+}
+
+.album-object.is-insert-open .album-insert {
+  box-shadow: 0 24px 70px rgba(0, 0, 0, 0.48);
+  transform: translate3d(58%, -50%, 0) rotate(1.4deg);
+}
+
+@media (hover: hover) and (pointer: fine) {
+  .album-object:hover .album-insert,
+  .album-object:focus-within .album-insert {
+    box-shadow: 0 24px 70px rgba(0, 0, 0, 0.48);
+    transform: translate3d(58%, -50%, 0) rotate(1.4deg);
+  }
+}
+
+.album-insert-toggle {
+  position: absolute;
+  right: 0;
+  bottom: 34px;
+  z-index: 4;
+  display: inline-flex;
+  min-height: 40px;
+  align-items: center;
+  gap: 8px;
+  padding: 8px 12px;
+  color: var(--paper);
+  border: 1px solid rgba(225, 187, 45, 0.42);
+  border-radius: 999px;
+  background: rgba(9, 9, 10, 0.88);
+  font-family: var(--font-display);
+  font-size: 0.55rem;
+  font-weight: 600;
+  letter-spacing: 0.06em;
+  text-transform: uppercase;
+  cursor: pointer;
+  transition: color 180ms ease, border-color 180ms ease, background 180ms ease;
+}
+
+.album-insert-toggle svg {
+  width: 15px;
+  height: 15px;
+  fill: none;
+  stroke: currentColor;
+  stroke-width: 1.8;
+  stroke-linecap: round;
+  stroke-linejoin: round;
+  transition: transform 380ms cubic-bezier(0.2, 0.7, 0.2, 1);
+}
+
+.album-insert-toggle:hover,
+.album-insert-toggle[aria-expanded="true"] {
+  color: var(--ink);
+  border-color: var(--gold);
+  background: var(--gold);
+}
+
+.album-insert-toggle[aria-expanded="true"] svg {
+  transform: rotate(180deg);
+}
+
+.album-object__hint {
+  position: absolute;
+  bottom: 0;
+  left: 2%;
+  margin: 0;
+  color: rgba(245, 240, 230, 0.56);
+  font-size: 0.66rem;
+  letter-spacing: 0.08em;
+  text-transform: uppercase;
+}
+
+@keyframes album-foil-sweep {
+  0%, 54% { transform: translateX(-72%) rotate(4deg); }
+  76%, 100% { transform: translateX(72%) rotate(4deg); }
+}
+
 .release-copy h3,
 .video-feature h3,
 .no-shows h3,
@@ -889,13 +1118,287 @@ main,
   font-variant-numeric: tabular-nums;
 }
 
+.track-list--insert {
+  position: relative;
+  z-index: 1;
+  margin: clamp(16px, 2.4vw, 26px) 0 0;
+}
+
+.track-list--insert li {
+  grid-template-columns: 24px minmax(0, 1fr) auto;
+  padding: clamp(6px, 1vw, 9px) 0;
+  color: #292216;
+  border-bottom-color: rgba(61, 47, 17, 0.18);
+  font-size: clamp(0.66rem, 1.2vw, 0.82rem);
+  line-height: 1.35;
+}
+
+.track-list--insert li::before,
+.track-list--insert time {
+  color: #806517;
+}
+
 .bandcamp-player {
   display: block;
   width: 100%;
   height: 120px;
+  margin-top: 26px;
   border: 0;
 }
 
+.album-panel-button {
+  width: 100%;
+  margin-top: 18px;
+}
+
+/* Immersive album player */
+.album-modal {
+  width: min(1160px, calc(100vw - 32px));
+  max-width: none;
+  max-height: calc(100svh - 32px);
+  padding: 0;
+  overflow: visible;
+  color: var(--paper);
+  border: 0;
+  background: transparent;
+  font-family: var(--font-body);
+}
+
+.album-modal::backdrop {
+  background:
+    radial-gradient(circle at 22% 30%, rgba(225, 187, 45, 0.12), transparent 30%),
+    rgba(2, 2, 3, 0.9);
+  -webkit-backdrop-filter: blur(14px) saturate(115%);
+  backdrop-filter: blur(14px) saturate(115%);
+}
+
+.album-modal[open] {
+  animation: album-modal-in 320ms cubic-bezier(0.16, 0.82, 0.2, 1) both;
+}
+
+.album-modal.is-fallback[open] {
+  position: fixed;
+  inset: 16px;
+  z-index: 1000;
+  display: block;
+  margin: auto;
+}
+
+.album-modal[open]::backdrop {
+  animation: member-backdrop-in 260ms ease both;
+}
+
+.album-modal__surface {
+  position: relative;
+  display: grid;
+  grid-template-columns: minmax(330px, 0.9fr) minmax(420px, 1.1fr);
+  max-height: calc(100svh - 32px);
+  overflow-y: auto;
+  overscroll-behavior: contain;
+  border: 1px solid rgba(225, 187, 45, 0.48);
+  background:
+    radial-gradient(circle at 92% 7%, rgba(166, 51, 45, 0.19), transparent 29%),
+    #0d0d0f;
+  box-shadow: 0 35px 130px rgba(0, 0, 0, 0.82);
+}
+
+.album-modal__close {
+  position: absolute;
+  top: 16px;
+  right: 16px;
+  z-index: 6;
+  display: grid;
+  width: 46px;
+  height: 46px;
+  padding: 0;
+  color: var(--paper);
+  border: 1px solid rgba(255, 255, 255, 0.3);
+  border-radius: 50%;
+  background: rgba(5, 5, 6, 0.86);
+  font-size: 1.6rem;
+  line-height: 1;
+  place-items: center;
+  cursor: pointer;
+  transition: color 180ms ease, border-color 180ms ease, transform 180ms ease;
+}
+
+.album-modal__close:hover {
+  color: var(--gold-light);
+  border-color: var(--gold);
+  transform: rotate(5deg);
+}
+
+.album-modal__visual {
+  position: sticky;
+  top: 0;
+  display: grid;
+  min-height: min(760px, calc(100svh - 34px));
+  align-content: center;
+  justify-items: center;
+  padding: clamp(40px, 6vw, 74px);
+  overflow: hidden;
+  background:
+    linear-gradient(145deg, rgba(225, 187, 45, 0.13), transparent 42%),
+    #080809;
+}
+
+.album-modal__visual::before {
+  content: "";
+  position: absolute;
+  inset: 0;
+  opacity: 0.2;
+  background-image: repeating-linear-gradient(118deg, transparent 0 14px, rgba(225, 187, 45, 0.13) 14px 15px);
+  pointer-events: none;
+}
+
+.album-modal__orbit {
+  position: absolute;
+  width: min(38vw, 470px);
+  aspect-ratio: 1;
+  border: 1px solid rgba(225, 187, 45, 0.25);
+  border-radius: 50%;
+  box-shadow:
+    0 0 0 26px rgba(225, 187, 45, 0.025),
+    0 0 0 58px rgba(225, 187, 45, 0.018);
+  animation: album-orbit-turn 24s linear infinite;
+}
+
+.album-modal__orbit::before,
+.album-modal__orbit::after {
+  content: "";
+  position: absolute;
+  border-radius: 50%;
+  background: var(--gold);
+  box-shadow: 0 0 18px rgba(225, 187, 45, 0.62);
+}
+
+.album-modal__orbit::before {
+  top: 9%;
+  left: 15%;
+  width: 8px;
+  height: 8px;
+}
+
+.album-modal__orbit::after {
+  right: 4%;
+  bottom: 27%;
+  width: 5px;
+  height: 5px;
+}
+
+.album-modal__artwork {
+  position: relative;
+  z-index: 2;
+  width: min(100%, 400px);
+  aspect-ratio: 1;
+  overflow: hidden;
+  box-shadow:
+    18px 20px 0 rgba(225, 187, 45, 0.13),
+    0 34px 90px rgba(0, 0, 0, 0.62);
+  transform: rotate(-1.3deg);
+}
+
+.album-modal__artwork img {
+  width: 100%;
+  height: 100%;
+  object-fit: cover;
+}
+
+.album-modal__artwork span {
+  position: absolute;
+  inset: 0;
+  background: linear-gradient(112deg, transparent 26%, rgba(255, 244, 180, 0.3) 45%, transparent 62%);
+  mix-blend-mode: screen;
+  animation: album-modal-shine 7s ease-in-out infinite;
+}
+
+.album-modal__visual > p {
+  position: relative;
+  z-index: 2;
+  margin: 32px 0 0;
+  color: rgba(245, 240, 230, 0.62);
+  font-family: var(--font-display);
+  font-size: 0.55rem;
+  letter-spacing: 0.12em;
+  text-transform: uppercase;
+}
+
+.album-modal__content {
+  padding: clamp(44px, 6vw, 76px);
+}
+
+.album-modal__content h2 {
+  margin-bottom: 18px;
+  font-family: var(--font-display);
+  font-size: clamp(2.1rem, 5vw, 4.5rem);
+  line-height: 1;
+}
+
+.album-modal__content > p:not(.release-kicker) {
+  max-width: 55ch;
+  margin-bottom: 0;
+  color: var(--muted);
+}
+
+.track-list--modal {
+  margin: 30px 0;
+}
+
+.album-modal__player {
+  display: block;
+  width: 100%;
+  height: 300px;
+  border: 0;
+}
+
+.album-modal__links {
+  display: grid;
+  grid-template-columns: repeat(2, minmax(0, 1fr));
+  margin-top: 24px;
+  border-top: 1px solid var(--line);
+  border-left: 1px solid var(--line);
+}
+
+.album-modal__links a {
+  display: flex;
+  min-height: 52px;
+  align-items: center;
+  justify-content: space-between;
+  padding: 12px 14px;
+  border-right: 1px solid var(--line);
+  border-bottom: 1px solid var(--line);
+  font-family: var(--font-display);
+  font-size: 0.56rem;
+  letter-spacing: 0.04em;
+  transition: color 180ms ease, background 180ms ease;
+}
+
+.album-modal__links a:hover {
+  color: var(--ink);
+  background: var(--gold);
+}
+
+@keyframes album-modal-in {
+  from {
+    opacity: 0;
+    transform: translateY(22px) scale(0.975);
+  }
+
+  to {
+    opacity: 1;
+    transform: translateY(0) scale(1);
+  }
+}
+
+@keyframes album-orbit-turn {
+  to { transform: rotate(360deg); }
+}
+
+@keyframes album-modal-shine {
+  0%, 52% { transform: translateX(-125%); }
+  78%, 100% { transform: translateX(125%); }
+}
+
