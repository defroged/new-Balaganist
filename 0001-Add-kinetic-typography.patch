 }
 
+/* Polyrhythmic kinetic typography: interlocking seven- and eleven-beat phrases. */
+.kinetic-title {
+  position: relative;
+  isolation: isolate;
+}
+
+.kinetic-word {
+  display: inline-block;
+  padding: 0.13em 0.025em 0.18em;
+  margin: -0.13em -0.025em -0.18em;
+  overflow: hidden;
+  line-height: inherit;
+  vertical-align: bottom;
+  white-space: nowrap;
+}
+
+.kinetic-letter,
+.kinetic-glyph {
+  display: inline-block;
+}
+
+.kinetic-letter {
+  color: inherit;
+  transform: translateZ(0);
+  transition:
+    color 280ms ease,
+    transform 520ms cubic-bezier(0.2, 0.75, 0.25, 1);
+  transition-delay: var(--kinetic-hover-delay, 0ms);
+}
+
+.kinetic-glyph {
+  --kinetic-entry-x: 0em;
+  --kinetic-entry-y: 116%;
+  --kinetic-entry-rotate: 0deg;
+  --kinetic-flash: var(--paper);
+  transform-origin: 50% 72%;
+  backface-visibility: hidden;
+}
+
+.kinetic-title--lead-7 .kinetic-letter--seven .kinetic-glyph {
+  --kinetic-entry-x: -0.34em;
+  --kinetic-entry-y: 72%;
+  --kinetic-entry-rotate: -6deg;
+  --kinetic-flash: var(--gold-light);
+}
+
+.kinetic-title--lead-7 .kinetic-letter--eleven .kinetic-glyph {
+  --kinetic-entry-x: 0.28em;
+  --kinetic-entry-y: -112%;
+  --kinetic-entry-rotate: 5deg;
+  --kinetic-flash: #ef806c;
+}
+
+.kinetic-title--lead-11 .kinetic-letter--seven .kinetic-glyph {
+  --kinetic-entry-x: -0.18em;
+  --kinetic-entry-y: 112%;
+  --kinetic-entry-rotate: -4deg;
+  --kinetic-flash: var(--gold-light);
+}
+
+.kinetic-title--lead-11 .kinetic-letter--eleven .kinetic-glyph {
+  --kinetic-entry-x: 0.36em;
+  --kinetic-entry-y: -72%;
+  --kinetic-entry-rotate: 7deg;
+  --kinetic-flash: #ef806c;
+}
+
+.kinetic-letter--both .kinetic-glyph {
+  --kinetic-entry-x: 0em;
+  --kinetic-entry-y: 0%;
+  --kinetic-entry-rotate: 9deg;
+  --kinetic-flash: #fff1a6;
+}
+
+.kinetic-title.is-kinetic-ready:not(.is-kinetic-visible) .kinetic-glyph {
+  opacity: 0;
+  filter: blur(3px);
+  transform:
+    translate3d(
+      var(--kinetic-entry-x),
+      var(--kinetic-entry-y),
+      0
+    )
+    rotate(var(--kinetic-entry-rotate));
+}
+
+.kinetic-title.is-kinetic-visible .kinetic-glyph {
+  animation: kinetic-glyph-in 820ms cubic-bezier(0.16, 0.78, 0.22, 1) both;
+  animation-delay: var(--kinetic-delay, 0ms);
+}
+
+.kinetic-title.is-kinetic-ready::after {
+  content: "";
+  position: absolute;
+  bottom: -0.23em;
+  left: 0;
+  width: min(230px, 42%);
+  height: 5px;
+  background-image:
+    repeating-linear-gradient(
+      90deg,
+      rgba(225, 187, 45, 0.95) 0 2px,
+      transparent 2px 14.2857%
+    ),
+    repeating-linear-gradient(
+      90deg,
+      rgba(245, 240, 230, 0.5) 0 1px,
+      transparent 1px 9.0909%
+    );
+  background-repeat: no-repeat;
+  background-position: 0 0, 0 4px;
+  background-size: 100% 2px, 100% 1px;
+  opacity: 0;
+  clip-path: inset(0 100% 0 0);
+  pointer-events: none;
+}
+
+.kinetic-title--lead-11.is-kinetic-ready::after {
+  clip-path: inset(0 0 0 100%);
+}
+
+.kinetic-title.is-kinetic-ready.is-kinetic-visible::after {
+  animation: kinetic-meter-in 900ms cubic-bezier(0.2, 0.72, 0.2, 1) forwards;
+  animation-delay: var(--kinetic-meter-delay, 400ms);
+}
+
+.hero__tagline.kinetic-title::after {
+  left: 50%;
+  width: min(190px, 46%);
+  transform: translateX(-50%);
+}
+
+@keyframes kinetic-glyph-in {
+  0% {
+    color: inherit;
+    opacity: 0;
+    filter: blur(3px);
+    text-shadow: none;
+    transform:
+      translate3d(
+        var(--kinetic-entry-x),
+        var(--kinetic-entry-y),
+        0
+      )
+      rotate(var(--kinetic-entry-rotate));
+  }
+  48% {
+    color: var(--kinetic-flash);
+    opacity: 1;
+    filter: blur(0);
+    text-shadow: 0 0 18px var(--kinetic-flash);
+  }
+  72% {
+    color: inherit;
+    text-shadow: none;
+    transform: translate3d(0, -0.055em, 0) rotate(0deg);
+  }
+  100% {
+    color: inherit;
+    opacity: 1;
+    filter: blur(0);
+    text-shadow: none;
+    transform: translate3d(0, 0, 0) rotate(0deg);
+  }
+}
+
+@keyframes kinetic-meter-in {
+  0% { opacity: 0; }
+  68% { opacity: 0.72; }
+  100% { opacity: 0.42; clip-path: inset(0); }
+}
+
+@media (hover: hover) and (pointer: fine) {
+  .kinetic-title.is-kinetic-visible:hover .kinetic-letter--seven {
+    color: var(--gold-light);
+    transform: translate3d(0, -0.075em, 0) rotate(-1deg);
+  }
+
+  .kinetic-title.is-kinetic-visible:hover .kinetic-letter--eleven {
+    color: #ef927f;
+    transform: translate3d(0.045em, 0.055em, 0) rotate(1.25deg);
+  }
+
+  .kinetic-title.is-kinetic-visible:hover .kinetic-letter--both {
+    color: #fff1a6;
+    transform: translate3d(0, -0.04em, 0) scale(1.09);
+  }
+}
+
 /* Release */
 .release-grid {
   position: relative;
@@ -1552,4 +1741,17 @@ main,
   .member-card.reveal.is-visible {
     transform: none;
   }
+
+  .kinetic-title.is-kinetic-ready .kinetic-glyph {
+    color: inherit;
+    opacity: 1;
+    filter: none;
+    text-shadow: none;
+    transform: none;
+    animation: none !important;
+  }
+
+  .kinetic-title.is-kinetic-ready::after {
+    display: none;
+  }
 }
